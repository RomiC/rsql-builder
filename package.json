{
  "name": "rsql-builder",
  "version": "1.3.3",
  "description": "RSQL query builder",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:test": "tsdown -c tsdown.tests.config.ts",
    "lint": "eslint",
    "lint:fix": "npm run lint -- --fix",
    "precommit": "lint-staged",
    "prepare": "husky install",
    "prepush": "npm run test && npm run test:smoke",
    "pretest": "npm run build:test",
    "pretest:no-coverage": "npm run build:test",
    "pretest:smoke": "npm run build",
    "test": "c8 --reporter=text --reporter=lcov --include=dist node --test tests/*.spec.js",
    "test:smoke": "node ./scripts/smoke-cjs.cjs && node ./scripts/smoke-esm.mjs",
    "test:no-coverage": "node --test tests/*.spec.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RomiC/rsql-builder.git"
  },
  "keywords": [
    "rsql",
    "query",
    "builder"
  ],
  "engines": {
    "node": ">= 22"
  },
  "overrides": {
    "yargs": "^18.0.0"
  },
  "author": "Roman Charugin <i@charugin.ru>",
  "contributors": [
    "Roman Charugin <i@charugin.ru>",
    "Mihael Šafarić <mihael.safaric@gmail.com>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/RomiC/rsql-builder/issues"
  },
  "homepage": "https://github.com/RomiC/rsql-builder#readme",
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "25.9.1",
    "c8": "^11.0.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "63.0.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "tsdown": "0.22.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0"
  },
  "lint-staged": {
    "*.ts": "npm run lint:fix"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false
}
