{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "esnext",
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "rootDir": "src",
    "outDir": "dist",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules/*", "examples/*"]
}
