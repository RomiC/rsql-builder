{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es2015",
    "declaration": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "outDir": "dist/cjs"
  },
  "include": ["src/**/*.ts", "*.ts"],
  "exclude": ["node_modules/*", "examples/*"]
}
