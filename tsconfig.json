{
  "compilerOptions": {
    "module": "commonjs",
    "esModuleInterop": true,
    "target": "es2015",
    "declaration": true,
    "noImplicitAny": true,
    "moduleResolution": "node10",
    "sourceMap": true,
    "outDir": "dist/cjs",
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/*", "*.ts"],
  "exclude": ["node_modules/*", "examples/*"]
}
